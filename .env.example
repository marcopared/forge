# Wave 0 local execution defaults.
# Copy to `.env` only if you want to override the local-first defaults.

FORGE_NODE_ENV=development
FORGE_DEFAULT_WAVE_ID=wave-0-live
FORGE_DEFAULT_PACKET_ID=WAVE0-SYNTHETIC
FORGE_DEFAULT_BENCHMARK_ID=wave0-live-smoke
FORGE_PHASE_BRANCH=forge/phase-0-wave0-synthetic
FORGE_LAUNCH_MODE=operator-launched
FORGE_OPERATOR_REVIEW=human-required
FORGE_WAVE_CONCURRENCY=1
FORGE_PACKET_REGISTRY_REF=packets/validation/packet-registry.yaml
FORGE_WAVE_MANIFEST_REF=packets/waves/wave0-live.yaml
FORGE_BENCHMARK_MANIFEST_REF=benchmarks/manifests/wave0-live-smoke.yaml

FORGE_POSTGRES_HOST=127.0.0.1
FORGE_POSTGRES_PORT=5432
FORGE_POSTGRES_DB=forge
FORGE_POSTGRES_USER=forge
FORGE_POSTGRES_PASSWORD=forge
FORGE_DB_SCHEMA=forge_local
FORGE_DATABASE_URL=postgresql://forge:forge@127.0.0.1:5432/forge

FORGE_REDIS_HOST=127.0.0.1
FORGE_REDIS_PORT=6379
FORGE_REDIS_URL=redis://127.0.0.1:6379

FORGE_FILES_ROOT=./files
FORGE_STORAGE_ROOT=./var
FORGE_BLOB_ROOT=./var/blob
FORGE_EVIDENCE_ROOT=./var/evidence
FORGE_AUDIT_ROOT=./var/audit
FORGE_LOG_ROOT=./var/logs
FORGE_WORKTREE_ROOT=./var/worktrees
