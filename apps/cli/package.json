{
  "name": "@forge/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bootstrap": "node --import tsx src/index.ts bootstrap",
    "doctor": "node --import tsx src/index.ts doctor",
    "print-config": "node --import tsx src/index.ts print-config",
    "runtime:provision": "node --import tsx src/index.ts runtime:provision",
    "runtime:diff": "node --import tsx src/index.ts runtime:diff",
    "runtime:merge": "node --import tsx src/index.ts runtime:merge",
    "runtime:rollback": "node --import tsx src/index.ts runtime:rollback",
    "runtime:teardown": "node --import tsx src/index.ts runtime:teardown",
    "wave0:launch": "node --import tsx src/index.ts wave0:launch",
    "wave0:run": "node --import tsx src/index.ts wave0:run",
    "wave0:status": "node --import tsx src/index.ts wave0:status",
    "wave0:packet-status": "node --import tsx src/index.ts wave0:packet-status",
    "wave0:validators": "node --import tsx src/index.ts wave0:validators",
    "wave0:evidence": "node --import tsx src/index.ts wave0:evidence",
    "wave0:policy-log": "node --import tsx src/index.ts wave0:policy-log",
    "wave0:audit": "node --import tsx src/index.ts wave0:audit",
    "wave0:pause": "node --import tsx src/index.ts wave0:pause",
    "wave0:abort": "node --import tsx src/index.ts wave0:abort",
    "wave0:resume": "node --import tsx src/index.ts wave0:resume",
    "wave0:rollback": "node --import tsx src/index.ts wave0:rollback",
    "wave0:closeout": "node --import tsx src/index.ts wave0:closeout",
    "wave0:inspect": "node --import tsx src/index.ts wave0:inspect"
  },
  "dependencies": {
    "@forge/agent-runner": "workspace:*",
    "@forge/config": "workspace:*",
    "@forge/db": "workspace:*",
    "@forge/evidence": "workspace:*",
    "@forge/orchestrator": "workspace:*",
    "@forge/policy-engine": "workspace:*",
    "@forge/runtime-manager": "workspace:*",
    "@forge/shared": "workspace:*",
    "@forge/storage": "workspace:*",
    "@forge/tool-broker": "workspace:*",
    "@forge/validator-runner": "workspace:*"
  }
}
