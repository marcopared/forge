{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@forge/shared": ["packages/shared/src/index.ts"],
      "@forge/orchestrator": ["packages/orchestrator/src/index.ts"],
      "@forge/agent-runner": ["packages/agent-runner/src/index.ts"],
      "@forge/runtime-manager": ["packages/runtime-manager/src/index.ts"],
      "@forge/policy-engine": ["packages/policy-engine/src/index.ts"],
      "@forge/tool-broker": ["packages/tool-broker/src/index.ts"],
      "@forge/validator-runner": ["packages/validator-runner/src/index.ts"],
      "@forge/evidence": ["packages/evidence/src/index.ts"],
      "@forge/storage": ["packages/storage/src/index.ts"],
      "@forge/config": ["packages/config/src/index.ts"],
      "@forge/db": ["packages/db/src/index.ts"]
    },
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["apps/**/*.ts", "packages/**/*.ts"],
  "exclude": ["dist", "node_modules", "files", "var"]
}
